---
import { ArrowUpRight, Moon, Sun } from '@lucide/astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a href="/" class="brand-link" aria-label="홈으로 이동">
			<span class="brand-eyebrow">YJK DEV LOG</span>
			<strong class="site-title">{SITE_TITLE}</strong>
		</a>
		<div class="header-actions">
			<a
				class="action-link github-link"
				href="https://github.com/Yong-joon-Kwak"
				target="_blank"
				rel="noreferrer noopener"
				aria-label="GitHub 프로필 열기"
			>
				<ArrowUpRight size={16} aria-hidden="true" />
				<span>GitHub</span>
			</a>
			<button id="theme-toggle" class="action-link theme-toggle" type="button" aria-label="테마 변경">
				<span class="theme-icon moon-icon" aria-hidden="true">
					<Moon size={16} />
				</span>
				<span class="theme-icon sun-icon" aria-hidden="true">
					<Sun size={16} />
				</span>
				<span class="toggle-label">테마</span>
			</button>
		</div>
	</nav>
</header>
<script is:inline>
	const root = document.documentElement;
	const themeToggle = document.querySelector('#theme-toggle');
	const storageKey = 'theme';

	const getCurrentTheme = () => root.getAttribute('data-theme') || 'light';

	const syncThemeUI = (theme) => {
		if (themeToggle) {
			themeToggle.setAttribute(
				'aria-label',
				theme === 'dark' ? '라이트 모드로 전환' : '다크 모드로 전환',
			);
		}
	};

	const applyTheme = (theme) => {
		root.setAttribute('data-theme', theme);
		localStorage.setItem(storageKey, theme);
		syncThemeUI(theme);
	};

	syncThemeUI(getCurrentTheme());

	if (themeToggle) {
		themeToggle.addEventListener('click', () => {
			const nextTheme = getCurrentTheme() === 'dark' ? 'light' : 'dark';
			applyTheme(nextTheme);
		});
	}
</script>
<style>
	header {
		margin: 0;
		padding: 0 20px;
		background: var(--bg);
		border-bottom: 1px solid var(--outline-variant);
		box-shadow: var(--header-shadow);
		position: sticky;
		top: 0;
		z-index: 100;
		transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		min-height: 76px;
		gap: 16px;
	}

	.brand-link {
		display: inline-flex;
		flex-direction: column;
		gap: 4px;
		text-decoration: none;
		min-width: 0;
	}

	.brand-eyebrow {
		font-size: 0.72rem;
		line-height: 1;
		letter-spacing: 0.08em;
		color: var(--text-muted);
	}

	.site-title {
		font-size: 1rem;
		line-height: 1.2;
		font-weight: 700;
		color: var(--text);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.header-actions {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	.action-link {
		height: 36px;
		padding: 0 0.7rem;
		border: 1px solid var(--outline);
		background: var(--surface-container);
		color: var(--text);
		border-radius: 9999px;
		line-height: 1;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		font-size: 0.8rem;
		font-weight: 500;
		transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
		text-decoration: none;
	}

	.action-link:hover {
		background: var(--surface-container-high);
		transform: translateY(-1px);
	}

	.action-link:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.theme-toggle {
		padding-inline: 0.65rem;
	}

	.theme-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.sun-icon {
		display: none;
	}

	html[data-theme='dark'] .moon-icon {
		display: none;
	}

	html[data-theme='dark'] .sun-icon {
		display: inline-flex;
	}

	@media (max-width: 768px) {
		nav {
			min-height: 68px;
		}

		.site-title {
			font-size: 0.95rem;
		}

		.brand-eyebrow {
			font-size: 0.68rem;
		}

		.action-link {
			height: 34px;
			padding-inline: 0.6rem;
		}

		.github-link span,
		.toggle-label {
			display: none;
		}
	}
</style>
