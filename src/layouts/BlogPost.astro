---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CustomHeadScripts from '../components/CustomHeadScripts.astro';
import CustomBodyScripts from '../components/CustomBodyScripts.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
const pageTitle = title + ' | ' + SITE_TITLE;
---

<html lang="ko">
	<head>
		<BaseHead title={pageTitle} description={description} />
		<CustomHeadScripts />
		<style>
			#post-progress {
				position: fixed;
				top: 0;
				left: 0;
				height: 3px;
				width: 0;
				background: var(--accent);
				transition: width 0.1s linear, background-color 0.2s ease;
				z-index: 9999;
			}

			main {
				width: 100%;
				max-width: 100%;
				padding-top: 2rem;
			}

			.hero-image {
				width: min(1020px, calc(100% - 40px));
				margin: 0 auto;
			}

			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 1rem;
				box-shadow: var(--hero-shadow);
			}

			.prose {
				width: 720px;
				max-width: calc(100% - 40px);
				margin: auto;
				padding: 1.5rem 20px;
				color: var(--text);
			}

			.title {
				margin-bottom: 1em;
				padding: 1.5rem 0 1rem;
				line-height: 1;
			}

			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2rem;
				line-height: 1.25;
				letter-spacing: -0.02em;
			}

			.date {
				margin-bottom: 0.5em;
				color: var(--text-muted);
			}

			.last-updated-on {
				font-style: italic;
			}

			@media (max-width: 768px) {
				main {
					padding-top: 1.5rem;
				}

				.prose {
					max-width: calc(100% - 40px);
					padding: 1.25rem 20px;
				}

				.title {
					padding-top: 1rem;
				}

				.title h1 {
					font-size: 1.6rem;
					line-height: 1.3;
					letter-spacing: -0.01em;
				}
			}
		</style>
	</head>

	<body>
		<CustomBodyScripts />
		<div id="post-progress" aria-hidden="true"></div>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script is:inline>
			const progressBar = document.querySelector('#post-progress');

			const updateProgress = () => {
				if (!progressBar) return;
				const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
				const scrollHeight =
					document.documentElement.scrollHeight - document.documentElement.clientHeight;

				if (scrollHeight <= 0) {
					progressBar.style.width = '0%';
					return;
				}

				const progress = Math.min(100, Math.max(0, (scrollTop / scrollHeight) * 100));
				progressBar.style.width = `${progress}%`;
			};

			updateProgress();
			window.addEventListener('scroll', updateProgress, { passive: true });
			window.addEventListener('resize', updateProgress);
		</script>
	</body>
</html>
